# Limpio — Production Environment Variables
# Copy this file to .env.local and fill in the values

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- Supabase Auth redirect URLs ---
# Add these to Supabase Dashboard → Authentication → URL Configuration:
#
# Site URL:
#   https://your-domain.com
#
# Redirect URLs (add all of these):
#   https://your-domain.com/api/auth/callback
#   https://your-domain.com/es/auth/onboarding
#   https://your-domain.com/en/auth/onboarding
#   https://your-domain.com/es/auth/update-password
#   https://your-domain.com/en/auth/update-password
#
# For local development, also add:
#   http://localhost:3000/api/auth/callback
#   http://localhost:3000/es/auth/onboarding
#   http://localhost:3000/en/auth/onboarding

# --- Vercel deployment ---
# Set these in Vercel Dashboard → Project → Settings → Environment Variables
# Never commit real values to git!
